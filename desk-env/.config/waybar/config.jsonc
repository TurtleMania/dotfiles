// -*- mode: jsonc -*-
{
    "layer": "bot",
    "spacing": 8,
    "margin-bottom": 0,
    "margin-top": 10,
    "position": "top",
    "margin-right": 10,
    "margin-left": 10,

    "reload_style_on_change": true,

    "modules-left": [
        "custom/arch",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "mpris"
    ],
    "modules-right": [
        "group/hardware",
        "privacy",
        "backlight",
        "pulseaudio",
        "battery",
        "clock"
    ],

    "hyprland/workspaces": {
        "format": "ïٹں",
        "persistent-workspaces": {
            "*": 4
        }
    },

    "custom/arch": {
        "format": "َ°£‡"
    },

    "mpris": {
        "format": "{status_icon}  {dynamic} {player_icon}",
        "interval": 1,
        "ignored-players": [
            "firefox"
        ],
        "player-icons": {
            "ncspot": "َ°“‡â€‰"
        },
        "status-icons": {
            "playing": "ïپ‹",
            "paused": "ïپŒ",
            "stopped": "ïپچ"
        },
        "dynamic-order": [
            "artist",
            "title",
            "position",
            "length"
        ]
    },

    "backlight": {
        "format": "{icon}",
        "tooltip-format": "{percent}%",
        "format-icons": [
            "ًںŒ‘", "ًںŒک", "ًںŒک", "ًںŒک", "ًںŒ—", "ًںŒ—", "ًںŒ—", "ًںŒ—", "ًںŒ—",
            "ًںŒ–", "ًںŒ–", "ًںŒ–", "ًںŒ–", "ًںŒ–", "ًںŒ–", "ًںŒ–", "ًںŒ–", "ًںŒ•",
            "ًںŒ•"
        ] // Hacky thing to work better with exponential brightness
    },

    "pulseaudio": {
        "format": "{icon}â€‰â€‰â€‰",
        "format-muted": "î»¨",
        "tooltip-format": "{volume}%",
        "format-icons": [
            "ï€¦", "ï€§", "ï€¨"
        ]
    },

    "battery": {
        "format": "{icon}",
        "tooltip-format": "{capacity}% {timeTo}",
        "format-icons": [
            "َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"
        ]
    },

    "clock": {
        "tooltip-format": "<tt>{calendar}</tt>",
    },

    "privacy": {
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-out",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ],
    },

    "group/hardware": {
        "orientation": "inherit",
        "drawer": {},
        "modules": [
            "custom/hardware-icon",
            "custom/seperator",
            "cpu",
            "custom/seperator",
            "memory",
            "custom/seperator",
            "memory#swap",
            "custom/seperator",
            "disk",
            "custom/seperator",
            "temperature",
            "network",
            "custom/seperator"
        ]
    },

    "custom/hardware-icon": {
        "format": "َ°‡…",
        "tooltip": false // TODO Set tooltip to fastfetch output without logo
    },

    "custom/seperator": {
        "format": "|",
        "tooltip": false
    },
    
    "cpu": {
        "format": "{usage}% ï’¼ "
    },

    "memory": {
        "format": "{percentage}% î؟… ",
        "tooltip-format": "{used:0.1f} / {total:0.1f} GiB used"
    },

    "memory#swap": {
        "format": "{swapPercentage}% َ°“، ",
        "tooltip-format": "{swapUsed:0.1f} / {swapTotal:0.1f} GiB used"
    },

    "disk": {
        "format": "{percentage_used}% ïƒ‡ ",
        "tooltip-format": "{used} / {total} used on \"{path}\""
    },

    "temperature": {
        "format": "{icon}â€‰â€‰",
        "tooltip-format": "{temperatureC}َ°”„",
        "format-icons": [
            "ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"
        ]
    },

    "network": {
        "format": "{ifname}",
        "format-ethernet": "î½„",
        "format-wifi": "{icon} ",
        "format-disconnected": "َ°¤­ ",
        "format-disabled": "",
        "tooltip-format": "",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-wifi": "Frequency: {frequency}\nSignal Strength: {signalStrength}%\nUpload: {bandwidthUpBytes}\nDownload: {bandwidthDownBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "tooltip-format-disabled": "",
        "format-icons": [
            "َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"
        ]
    }
}
